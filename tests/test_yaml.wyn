fn yaml_parse(content: string) -> HashMap {
    var map = HashMap.new()
    var lines = content.split("\n")
    for line in lines {
        var trimmed = line.trim()
        if trimmed.len() == 0 { continue }
        if trimmed.starts_with("#") { continue }
        var colon = -1
        for i in 0..trimmed.len() {
            if trimmed[i] == ":" {
                colon = i
                break
            }
        }
        if colon > 0 {
            var key = trimmed.substring(0, colon).trim()
            var val = trimmed.substring(colon + 1, trimmed.len()).trim()
            map.insert(key, val)
        }
    }
    return map
}

fn main() -> int {
    // Basic parsing
    var data = yaml_parse("name: Alice\nage: 30\n# comment\nactive: true")
    assert_eq(data.get("name"), "Alice")
    assert_eq(data.get("age"), "30")
    assert_eq(data.get("active"), "true")

    // Empty input
    var empty = yaml_parse("")
    assert_eq(empty.len(), 0)

    // Comments only
    var comments = yaml_parse("# only comments\n# nothing here")
    assert_eq(comments.len(), 0)

    // Colon in value (URL)
    var url_data = yaml_parse("url: http://example.com:8080/path")
    assert_eq(url_data.get("url"), "http://example.com:8080/path")

    // Empty value
    var ev = yaml_parse("key:")
    assert_eq(ev.get("key"), "")

    // Whitespace trimming
    var ws = yaml_parse("  name  :  Alice Bob  ")
    assert_eq(ws.get("name"), "Alice Bob")

    println("yaml: 9 tests passed")
    return 0
}
